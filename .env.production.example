# Production on home server (192.168.0.146) — copy to .env on the server
NODE_ENV=production
PORT=3010

# Local document storage (PDFs, images, text files linked to sources)
STORAGE_PATH="./storage"

# Administrator password (required for access from outside your LAN).
# Access from private LAN IPs (192.168.x.x, 10.x.x.x, etc.) does not require a password.
ADMIN_PASSWORD="change-me-to-a-strong-password"

# Optional: secret for signing login cookies (defaults to a hash of ADMIN_PASSWORD).
# SESSION_SECRET="long-random-string"

# Postgres runs on the same host as the app
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres"
